# Puerto (Railway/Render asignan PORT en producción; en local usá 4000)
PORT=4000

# Origen del frontend (CORS). En producción: https://TU-USUARIO.github.io
# En local: http://localhost:4200
CORS_ORIGIN=http://localhost:4200

# URL base del front para redirecciones tras OAuth (ML/TN). En GitHub Pages debe incluir el path del repo.
# Ej.: https://TU-USUARIO.github.io/zc-hub (con o sin barra final). Si no se define, se usa CORS_ORIGIN + /
FRONTEND_URL=http://localhost:4200/

# Mercado Libre - https://developers.mercadolibre.com.ar/devcenter/
ML_CLIENT_ID=tu_client_id
ML_CLIENT_SECRET=tu_client_secret
# En producción: https://TU-DOMINIO.up.railway.app/api/auth/mercadolibre/callback (Railway) o .onrender.com (Render)
# En desarrollo: tu URL de ngrok
ML_REDIRECT_URI=https://TU-URL-NGROK.ngrok-free.dev/api/auth/mercadolibre/callback

# Tienda Nube - https://partners.tiendanube.com/
TN_CLIENT_ID=tu_app_id
TN_CLIENT_SECRET=tu_client_secret
# En producción: https://TU-DOMINIO.up.railway.app/api/auth/tiendanube/callback (Railway) o .onrender.com (Render)
TN_REDIRECT_URI=https://TU-URL-NGROK.ngrok-free.dev/api/auth/tiendanube/callback

# URL pública del backend (webhooks y redirects). En producción: https://TU-DOMINIO.up.railway.app (Railway) o .onrender.com (Render)
WEBHOOK_BASE_URL=https://TU-URL-NGROK.ngrok-free.dev

# Postgres (Supabase u otro). Recomendado para sync y auditoría.
# DATABASE_URL=postgresql://postgres.[PROJECT]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DATABASE_URL=

# Límite de requests a la API de Mercado Libre (evita errores 429). Opcionales.
# ML_MAX_CONCURRENT: máximo de requests a ML en vuelo a la vez (default 4).
# ML_MIN_SPACING_MS: espaciado mínimo entre requests en ms (default 350, ~170 req/min).
# Si seguís viendo 429, subí ML_MIN_SPACING_MS (ej. 600) o bajá ML_MAX_CONCURRENT.
# ML_MAX_CONCURRENT=4
# ML_MIN_SPACING_MS=350
