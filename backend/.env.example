# Puerto (Render asigna PORT en producción; en local usá 4000)
PORT=4000

# Origen del frontend (CORS). En producción: https://TU-USUARIO.github.io
# En local: http://localhost:4200
CORS_ORIGIN=http://localhost:4200

# Mercado Libre - https://developers.mercadolibre.com.ar/devcenter/
ML_CLIENT_ID=tu_client_id
ML_CLIENT_SECRET=tu_client_secret
# En producción: https://TU-BACKEND.onrender.com/api/auth/mercadolibre/callback
# En desarrollo: tu URL de ngrok
ML_REDIRECT_URI=https://TU-URL-NGROK.ngrok-free.dev/api/auth/mercadolibre/callback

# Tienda Nube - https://partners.tiendanube.com/
TN_CLIENT_ID=tu_app_id
TN_CLIENT_SECRET=tu_client_secret
# En producción: https://TU-BACKEND.onrender.com/api/auth/tiendanube/callback
TN_REDIRECT_URI=https://TU-URL-NGROK.ngrok-free.dev/api/auth/tiendanube/callback

# URL pública del backend (webhooks y redirects). En producción: https://TU-BACKEND.onrender.com
WEBHOOK_BASE_URL=https://TU-URL-NGROK.ngrok-free.dev

# Postgres (Supabase u otro). Recomendado para sync y auditoría.
# DATABASE_URL=postgresql://postgres.[PROJECT]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DATABASE_URL=
